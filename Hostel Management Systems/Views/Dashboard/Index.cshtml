                        <p class="card-sub">Enrolled in hostel</p>
                    </div>
                    <div class="card-icon-box">
                        <i class="fa-solid fa-users"></i>
                    </div>
                </div>
				</a>
            </div>

            <div class="dashboard-card card-blue">
