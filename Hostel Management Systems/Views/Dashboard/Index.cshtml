                    <div class="card-left">
                        <span class="card-title">TOTAL ROOMS</span>
                        <h2>@Model.TotalRooms</h2>
                        <p class="card-sub">Total built rooms</p>
                    </div>
                    <div class="card-icon-box">
                        <i class="fa-solid fa-bed"></i>
                    </div>
                </div>
            </div>

            <div class="dashboard-card card-green">
                <div class="card-inner">
                    <div class="card-left">
                        <span class="card-title">AVAILABLE ROOMS</span>
                        <h2>@Model.AvailableRooms</h2>
                        <p class="card-sub">Ready to allocate</p>
                    </div>
                    <div class="card-icon-box">
                        <i class="fa-solid fa-door-open"></i>
                    </div>
                </div>
            </div>

            <div class="dashboard-card card-red">
                <div class="card-inner">
                    <div class="card-left">
                        <span class="card-title">FULL ROOMS</span>
                        <h2>@Model.FullRooms</h2>
                        <p class="card-sub">Completely occupied</p>
                    </div>
                    <div class="card-icon-box">
                        <i class="fa-solid fa-house-lock"></i>
                    </div>
                </div>
            </div>

            <div class="dashboard-card card-orange">
                <div class="card-inner">
                    <div class="card-left">
                        <span class="card-title">PENDING COMPLAINTS</span>
                        <h2>@Model.PendingComplaints</h2>
                        <p class="card-sub">Requires attention</p>
                    </div>
                    <div class="card-icon-box">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                </div>
            </div>

            <div class="dashboard-card card-teal">
                <div class="card-inner">
                    <div class="card-left">
                        <span class="card-title">RESOLVED COMPLAINTS</span>
                        <h2>@Model.ResolvedComplaints</h2>
                        <p class="card-sub">Successfully closed</p>
                    </div>
                    <div class="card-icon-box">
                        <i class="fa-solid fa-circle-check"></i>
                    </div>
                </div>
            </div>

            <div class="dashboard-card card-pink">
                <div class="card-inner">
                    <div class="card-left">
                        <span class="card-title">PENDING FEES</span>
                        <h2>@Model.PendingFees</h2>
                        <p class="card-sub">Unpaid dues</p>
                    </div>
                    <div class="card-icon-box">
                        <i class="fa-solid fa-indian-rupee-sign"></i>
                    </div>
                </div>
            </div>

            <div class="dashboard-card card-emerald">
                <div class="card-inner">
                    <div class="card-left">
                        <span class="card-title">PAID FEES</span>
                        <h2>@Model.PaidFees</h2>
                        <p class="card-sub">Collected amount</p>
                    </div>
                    <div class="card-icon-box">
                        <i class="fa-solid fa-wallet"></i>
                    </div>
                </div>
            </div>

        </div>


        </div>

    </div>
