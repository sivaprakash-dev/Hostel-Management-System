@model List<Student>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
    /* ===================================================
           1. பொதுவான அமைப்புகள் (GLOBAL CONFIGURATION)
           =================================================== */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Poppins', sans-serif;
    }

    body {
        background-color: #f8fafc;
        color: #1e293b;
        overflow-x: hidden;
    }

    .main-container {
        display: flex;
        min-height: 100vh;
        width: 100%;
    }

    /* ===================================================
           2. சைட்பார் வடிவமைப்பு (SIDEBAR - Stomp Effect Included)
           =================================================== */
    .sidebar {
        width: 260px;
        background-color: #0f0a1c;
        color: #a5a2ba;
        display: flex;
        flex-direction: column;
        padding: 24px 16px;
        flex-shrink: 0;
    }

    .logo-section {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-bottom: 20px;
        margin-bottom: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .sidebar .logo {
        background: linear-gradient(135deg, #b034cc, #6a11cb);
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 18px;
    }

    .logo-text h3 {
        color: #fff;
        font-size: 16px;
        font-weight: 600;
    }

    .logo-text p {
        font-size: 11px;
        color: #5c5776;
    }

    .menu-title {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 1.5px;
        color: #433e58;
        margin: 10px 0 12px 12px;
    }

    .sidebar ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .sidebar ul li a {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 14px 16px;
            color: #8a85a5;
            text-decoration: none;
            border-radius: 14px;
            font-size: 14px;
            font-weight: 500;
            position: relative;
            /*
               STOMP EFFECT BASE:
               cubic-bezier அனிமேஷன் மூலம் ஒரு ஸ்பிரிங் அல்லது ஸ்டம்ப் போன்ற எஃபெக்ட் கிடைக்கும்
            */
            transition: transform 0.15s cubic-bezier(0.25, 0.8, 0.25, 1.4), background-color 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
        }

            /* HOVER STOMP: மவுஸை வைக்கும் போது லேசாகப் பெரிதாகும் */
            .sidebar ul li a:hover {
                color: #fff;
                background-color: rgba(255, 255, 255, 0.04);
                transform: scale(1.03); /* லேசான விரிவாக்கம் */
            }

            /* CLICK/ACTIVE STOMP (The True Stomp Effect):
           மெனுவைக் கிளிக் செய்யும் போது (Mousedown / Active) உள்ளே அழுந்திப் பதியும் ஸ்பிரிங் போன்ற எஃபெக்ட் */
            .sidebar ul li a:active {
                transform: scale(0.92) translateY(2px); /* மெனு கார்டு உள்ளே அமுங்கித் திரும்பும் */
                box-shadow: inset 0 3px 8px rgba(0, 0, 0, 0.5);
            }

        /* ஆக்டிவ் மெனுவிற்கான லீனியர் கிரேடியன்ட் */
        .sidebar ul li.active-menu a {
            background: linear-gradient(90deg, #b83cd1, #8418a8) !important;
            color: #fff !important;
            box-shadow: 0 4px 20px rgba(184, 60, 209, 0.4);
            font-weight: 600;
        }

            /* ஆக்டிவ் மெனுவின் வலதுபுற சிறிய புள்ளி */
            .sidebar ul li.active-menu a::after {
                content: '';
                position: absolute;
                right: 18px;
                width: 6px;
                height: 6px;
                background-color: #fff;
                border-radius: 50%;
            }

    /* ===================================================
           3. மின்னஞ்சல் பாக்ஸ் & சிவப்பு நிற லாக்அவுட் (BOTTOM FOOTER)
           =================================================== */
    .sidebar-footer {
        margin-top: auto;
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding-top: 20px;
    }

    .user-profile-box {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px;
        background-color: #17112a;
        border-radius: 16px;
    }

    .profile-avatar {
        background: linear-gradient(135deg, #bf55ec, #8e44ad);
        color: #fff;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 13px;
    }

    .profile-info h4 {
        color: #fff;
        font-size: 13px;
        font-weight: 500;
    }

    .profile-info p {
        font-size: 11px;
        color: #6a6485;
    }

    .logout-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        color: #ff4d4d !important;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: transform 0.15s cubic-bezier(0.25, 0.8, 0.25, 1.4), opacity 0.2s;
    }

        .logout-link:hover {
            opacity: 0.9;
            transform: scale(1.03);
        }

        .logout-link:active {
            transform: scale(0.92) translateY(2px);
        }

    /* ===================================================
           4. டாப் பார் வடிவமைப்பு (TOPBAR)
           =================================================== */
    .content {
        flex-grow: 1;
        padding: 24px 32px;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #ffffff;
        padding: 16px 24px;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.015);
        margin-bottom: 24px;
    }

    .topbar-left h2 {
        font-size: 18px;
        font-weight: 600;
        color: #0f172a;
    }

    .topbar-right {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .notification-icon {
        font-size: 18px;
        color: #64748b;
        cursor: pointer;
    }

    .top-useremail {
        font-size: 13px;
        color: #64748b;
    }

    .avatar-sm {
        background: #a855f7;
        color: #fff;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 600;
    }

    /* ===================================================
           5. கன்டென்ட் டைட்டில் மற்றும் டேபிள் வடிவமைப்பு
           =================================================== */
    .top-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: #0f172a;
    }

    .add-btn {
        background-color: #7c3aed;
        color: white;
        padding: 10px 20px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 500;
        font-size: 14px;
        transition: transform 0.1s ease, background-color 0.2s;
    }

        .add-btn:hover {
            background-color: #6d28d9;
        }

        .add-btn:active {
            transform: scale(0.95);
        }

    .table-container {
        background: #ffffff;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

    th {
        background-color: #f8fafc;
        color: #64748b;
        font-size: 13px;
        font-weight: 600;
        padding: 16px;
        border-bottom: 1px solid #edf2f7;
    }

    td {
        padding: 16px;
        font-size: 13.5px;
        color: #334155;
        border-bottom: 1px solid #f1f5f9;
    }

    tr:hover td {
        background-color: #f8fafc;
    }

    .details-btn, .edit-btn, .delete-btn {
        padding: 6px 12px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 12px;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: transform 0.1s ease;
    }

    .details-btn {
        background-color: #eff6ff;
        color: #1d4ed8;
    }

    .edit-btn {
        background-color: #fef3c7;
        color: #d97706;
    }

    .delete-btn {
        background-color: #fee2e2;
        color: #dc2626;
    }

    .details-btn:hover {
        background-color: #dbeafe;
    }

    .edit-btn:hover {
        background-color: #fde68a;
    }

    .delete-btn:hover {
        background-color: #fecaca;
    }

    .details-btn:active, .edit-btn:active, .delete-btn:active {
        transform: scale(0.95);
    }

   


    /* --- Smart Hostel Theme Variables --- */
    :root {
        --primary-purple: #7c3aed; /* "+ Add Student" மற்றும் Active page-ல் இருக்கும் அதே பர்பிள் */
        --purple-hover: #6d28d9;
        --text-dark: #374151;
        --border-light: #e5e7eb;
        --input-bg: #ffffff;
        --clear-text: #6b7280;
        --radius: 6px;
    }

    /* --- Search Section Styles --- */
    .table-header {
        margin-bottom: 1.5rem;
        margin-top: 1rem;
    }

    .search-form {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

        /* Search Input Box */
        .search-form input[type="text"] {
            min-width: 320px;
            padding: 0.55rem 1rem;
            font-size: 0.9rem;
            color: var(--text-dark);
            background-color: var(--input-bg);
            border: 1px solid var(--border-light);
            border-radius: var(--radius);
            outline: none;
            transition: all 0.2s ease;
        }

            .search-form input[type="text"]::placeholder {
                color: #9ca3af;
            }

            .search-form input[type="text"]:focus {
                border-color: var(--primary-purple);
                box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.15);
            }

    /* Search Button */
    .search-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.55rem 1.2rem;
        background-color: var(--primary-purple);
        color: #ffffff;
        font-size: 0.9rem;
        font-weight: 500;
        border: none;
        border-radius: var(--radius);
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .search-btn:hover {
            background-color: var(--purple-hover);
        }

    /* Clear Link Button */
    .clear-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--clear-text);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        padding: 0.55rem 0.75rem;
        border-radius: var(--radius);
        transition: all 0.2s ease;
    }

        .clear-btn:hover {
            color: #ef4444; /* Hover செய்யும்போது லேசான சிவப்பு நிறம் */
            background-color: #f9fafb;
        }


    /* --- Pagination Section Styles --- */
    .pagination-container {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        margin-top: 1.5rem;
        padding: 0.5rem 0;
    }

    /* Common style for page buttons and numbers */
    .page-btn, .page-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: var(--text-dark);
        font-size: 0.9rem;
        font-weight: 500;
        background-color: #ffffff;
        border: 1px solid var(--border-light);
        border-radius: var(--radius);
        transition: all 0.2s ease;
    }

    /* Next / Previous Buttons */
    .page-btn {
        padding: 0.5rem 1rem;
    }

    /* Individual Numbers (Square styling) */
    .page-number {
        min-width: 36px;
        height: 36px;
    }

        /* Hover effect */
        .page-btn:hover, .page-number:hover {
            background-color: #f3f4f6;
            border-color: #d1d5db;
            color: #111827;
        }

        /* Active Page (Purple highlight like Dashboard menu) */
        .page-number.active-page {
            background-color: var(--primary-purple);
            color: #ffffff;
            border-color: var(--primary-purple);
            pointer-events: none; /* Active பக்கத்தை மீண்டும் கிளிக் செய்ய முடியாதவாறு தடுக்க */
        }


    /* --- Responsive Adjustments --- */
    @@media (max-width: 640px) {
        .search-form {
            flex-direction: column;
            align-items: stroke;
        }

            .search-form input[type="text"] {
                width: 100%;
            }

        .search-btn, .clear-btn {
            justify-content: center;
            width: 100%;
        }
    }

    /* Google Font - தூய்மையான மற்றும் நேர்த்தியான லுக் தர */
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

    .profile-section {
        display: flex;
        align-items: center;
        gap: 16px; /* ஐகானுக்கும் உரைக்கும் இடையே உள்ள இடைவெளி */
        padding: 16px;
        background: rgba(255, 255, 255, 0.03); /* லேசான பின்னணி வண்ணம் */
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.06); /* Glassmorphic பார்டர் */
        margin-bottom: 24px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* மவுஸ் மேலே செல்லும்போது லேசான பளபளப்பு அனிமேஷன் */
    .profile-section:hover {
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(139, 92, 246, 0.3); /* Purple Glow */
        transform: translateY(-2px);
    }

    /* 1. Profile User Icon */
    .profile-icon {
        font-size: 45px;
        background: linear-gradient(135deg, #a855f7, #6366f1); /* இமேஜில் உள்ள நியான்றிக் பர்பிள் கிரேடியன்ட் */
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        filter: drop-shadow(0 4px 12px rgba(99, 102, 241, 0.3));
        transition: transform 0.3s ease;
    }

    .profile-section:hover .profile-icon {
        transform: scale(1.08) rotate(5deg);
    }

    /* 2. Email & Role Container */
    .profile-section .email {
        display: flex;
        flex-direction: column;
        gap: 4px; /* வரிகளுக்கு இடையே உள்ள இடைவெளி */
        overflow: hidden;
    }

        /* 3. Email Text Style */
        .profile-section .email h3:nth-child(1) {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px;
            font-weight: 600;
            color: #ffffff; /* தூய வெள்ளை நிறம் */
            letter-spacing: 0.3px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis; /* நீண்ட மெயில் ஐடியாக இருந்தால் '...' என சுருங்கும் */
        }

        /* 4. Role (ADMIN / STUDENT) Badge Style */
        .profile-section .email h3:nth-child(2) {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase; /* எழுத்துக்களை Capitalize செய்ய */
            letter-spacing: 1px;
            /* Neon Badge Effect (இமேஜில் உள்ளது போன்ற வடிவமைப்பு) */
            background: linear-gradient(90deg, #8b5cf6, #d946ef);
            color: #ffffff;
            padding: 3px 10px;
            border-radius: 20px;
            width: max-content; /* உரைக்கு ஏற்றவாறு மட்டும் பேட்ஜ் சுருங்கும் */
            box-shadow: 0 2px 10px rgba(139, 92, 246, 0.4);
        }
</style>

<div class="main-container">

    <div class="sidebar">

        
        <div class="profile-section">

            <i class="fa-solid fa-circle-user profile-icon"></i>

            <div class="email">
                <h3>@Context.Session.GetString("Email")</h3>
                <h3>@Context.Session.GetString("Role")</h3>
            </div>
        </div>


        <p class="menu-title">MENU</p>
        <ul>
            <li>
                <a asp-controller="Dashboard" asp-action="Index">
                    <i class="fa-solid fa-house"></i>
                    <span class="menu-text">Dashboard</span>
                </a>
            </li>
            <li class="active-menu">
                <a asp-controller="Student" asp-action="Indexs">
                    <i class="fa-solid fa-users"></i>
                    <span class="menu-text">Students</span>
                </a>
            </li>
            <li>
                <a asp-controller="Room" asp-action="RoomIndex">
                    <i class="fa-solid fa-bed"></i>
                    <span class="menu-text">Rooms</span>
                </a>
            </li>
            <li>
                <a asp-controller="RoomAllocation" asp-action="Indes">
                    <i class="fa-solid fa-user-plus"></i>
                    <span class="menu-text">Rooms Allocation</span>
                </a>
            </li>
            <li>
                <a asp-controller="Fees" asp-action="feesIndex">
                    <i class="fa-solid fa-money-bill"></i>
                    <span class="menu-text">Fees</span>
                </a>
            </li>
            <li>
                <a asp-controller="Complaint" asp-action="CompIndex">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span class="menu-text">Complaints</span>
                </a>
            </li>
            <li>
                <a href="#">
                    <i class="fa-solid fa-gear"></i>
                    <span class="menu-text">Settings</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">
            <div class="user-profile-box">
                <div class="profile-avatar">
                    @{
                        var email = Context.Session.GetString("Email");

                        var initials = "AJ";

                        if (!string.IsNullOrEmpty(email))
                        {
                            initials = email.Substring(0, 2).ToUpper();
                        }
                    }

                    @initials
                </div>

                <div class="profile-info">
                    <h4>Admin</h4>
                    <p>@Context.Session.GetString("Email")</p>
                </div>
            </div>

            <a asp-controller="Account" asp-action="Logout" class="logout-link">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span class="menu-text">Logout</span>
            </a>
        </div>
    </div>

    <div class="content">
        <div class="topbar">
            <div class="topbar-left">
                <h2>Student Management</h2>
            </div>
            <div class="topbar-right">
                <div class="notification-icon">
                    <i class="fa-regular fa-bell"></i>
                </div>
                <span class="top-useremail">
                    @Context.Session.GetString("Email")
                </span>
                <div class="profile-avatar">
                    @{
                        var Email = Context.Session.GetString("Email");

                        var Initials = "AJ";

                        if (!string.IsNullOrEmpty(email))
                        {
                            initials = email.Substring(0, 2).ToUpper();
                        }
                    }

                    @initials
                </div>
            </div>
        </div>

        <div class="top-section">
            <h1 class="page-title">Students</h1>
            <a asp-action="Create" class="add-btn">
                <i class="fa-solid fa-plus"></i> Add Student
            </a>
        </div>

        <div class="table-header">

            <form method="get" class="search-form">

                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       placeholder="Search Name, Gender, Age, Mobile, Email..." />

                <button type="submit" class="search-btn">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    Search
                </button>

                <a asp-action="Indexs"
                   class="clear-btn">
                    <i class="fa-solid fa-xmark"></i>
                    Clear
                </a>

            </form>

        </div>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Gender</th>
                        <th>Age</th>
                        <th>Mobile</th>
                        <th>Email</th>
                        <th>Details</th>
                        <th>Edit</th>
                        <th>Delete</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.StudentId</td>
                            <td><strong>@item.Name</strong></td>
                            <td>@item.Gender</td>
                            <td>@item.Age</td>
                            <td>@item.Mobile</td>
                            <td>@item.Email</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.StudentId" class="details-btn">
                                    <i class="fa-regular fa-eye"></i> View Details
                                </a>
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.StudentId" class="edit-btn">
                                    <i class="fa-regular fa-pen-to-square"></i> Edit
                                </a>
                            </td>
                            <td>
                                <a href="javascript:void(0)"
                                   class="delete-btn deleteStudent"
                                   data-id="@item.StudentId">
                                    <i class="fa-regular fa-trash-can"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="pagination-container">

                @if (ViewBag.CurrentPage > 1)
                {
                    <a asp-action="Indexs"
                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                       asp-route-search="@ViewBag.Search"
                       class="page-btn">
                        Previous
                    </a>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a asp-action="Indexs"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search"
                       class="@(ViewBag.CurrentPage == i ? "page-number active-page" : "page-number")">
                        @i
                    </a>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a asp-action="Indexs"
                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                       asp-route-search="@ViewBag.Search"
                       class="page-btn">
                        Next
                    </a>
                }

            </div>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.deleteStudent').forEach(button => {

        button.addEventListener('click', function () {

            let studentId = this.getAttribute('data-id');

            Swal.fire({
                title: 'Delete Student?',
                text: "This record cannot be recovered!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Yes, Delete',
                cancelButtonText: 'Cancel'
            }).then((result) => {

                if (result.isConfirmed) {
                    window.location.href = '/Student/Delete/' + studentId;
                }

            });

        });

    });
</script>